# Copy this file to .env and fill in your actual values
# Never commit your real .env file!

# Optional: If you want to enable AI-powered element detection using OpenAI
# Leave empty if you just want the basic Playwright automation to run
OPENAI_API_KEY=your_openai_api_key_here

# Which browser to use: chromium, firefox, or webkit
# Default is chromium, works best for most sites
BROWSER=chromium

# Run in headless mode? true = no window, false = shows the browser
# Set false if you want to watch the agent work
HEADLESS=false

# How long to wait for elements before giving up (in milliseconds)
TIMEOUT=30000

# The target URL the agent should automate
TARGET_URL=https://ui.shadcn.com/docs/forms/react-hook-form

# What to fill in the Name field of the form
FILL_NAME=Tanishq Singh

# What to fill in the Description field of the form
FILL_DESCRIPTION=This form was auto-filled by a Playwright automation agent!
