# Copy this to .env and fill in your values

# NVIDIA NIM API key — free at https://build.nvidia.com
NVIDIA_API_KEY=your_nvidia_api_key_here

# LLM model for decisions — meta/llama-3.1-8b-instruct is fastest
LLM_MODEL=meta/llama-3.1-8b-instruct

# Browser settings
BROWSER=chromium
HEADLESS=false
TIMEOUT=30000

# What the agent should do
TARGET_URL=https://ui.shadcn.com/docs/forms/react-hook-form
FILL_NAME=Tanishq Singh
FILL_DESCRIPTION=This form was auto-filled by an AI agent using NVIDIA NIM and Playwright!

# Safety limit — how many LLM steps before we stop
MAX_STEPS=20
