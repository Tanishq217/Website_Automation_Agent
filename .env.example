# Copy this file to .env and fill in your values
# cp .env.example .env

# Get a free API key at https://build.nvidia.com
NVIDIA_API_KEY=your_nvidia_api_key_here

# Model to use — 70b gives the best results for multi-step reasoning
LLM_MODEL=meta/llama-3.3-70b-instruct

# The page the agent will automate
TARGET_URL=https://ui.shadcn.com/docs/forms/react-hook-form

# What gets typed into the form
FILL_NAME=Tanishq Singh
FILL_DESCRIPTION=This form was automatically filled by a browser automation agent built with Playwright and NVIDIA NIM.

# Browser settings
BROWSER=chromium
HEADLESS=false
TIMEOUT=30000

# How many LLM decision steps before giving up
MAX_STEPS=20
